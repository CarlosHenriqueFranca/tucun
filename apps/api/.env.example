# ============================================================
# TUCUN API — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# Application
NODE_ENV=development
PORT=3333

# Database
DATABASE_URL=postgresql://tucun:tucun_dev_password@localhost:5432/tucun

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=tucun_redis_dev

# JWT Secrets (minimum 64 characters for security)
JWT_ACCESS_SECRET=change_me_to_a_random_string_of_at_least_64_characters_here
JWT_REFRESH_SECRET=change_me_to_another_random_string_of_at_least_64_characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Rate Limiting
RATE_LIMIT_TTL=60000
RATE_LIMIT_REQUESTS=100

# Google OAuth (optional — leave empty to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3333/api/auth/google/callback

# Facebook OAuth (optional — leave empty to disable)
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_CALLBACK_URL=http://localhost:3333/api/auth/facebook/callback

# Z-API WhatsApp OTP (optional — leave empty to disable)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=
ZAPI_BASE_URL=https://api.z-api.io

# Asaas Payment Gateway (optional — sandbox for testing)
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# AWS S3 Storage (optional — uses local storage if empty)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=tucun-media

# Firebase Push Notifications (optional — gracefully disabled if empty)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Mapbox (for frontend maps)
NEXT_PUBLIC_MAPBOX_TOKEN=

# App URL (for OAuth callbacks and links)
APP_URL=http://localhost:3333
FRONTEND_URL=http://localhost:3000
