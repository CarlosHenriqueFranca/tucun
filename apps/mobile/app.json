{
  "expo": {
    "name": "Tucun",
    "slug": "tucun",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "tucun",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1628"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.tucun.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1628"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.tucun.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-camera",
      "expo-secure-store",
      [
        "@rnmapbox/maps",
        {
          "RNMapboxMapsImpl": "mapbox",
          "RNMapboxMapsDownloadToken": "sk.eyJ1IjoiY2FybG9zaGVucmlxdWVmcmFuY2EiLCJhIjoiY21udDd4b21zMDdiZTJwb2hxYmc2czd4byJ9.DcZ6In_38LXfxOxg1BWggA"
        }
      ]
    ],
    "extra": {
      "EXPO_PUBLIC_MAPBOX_TOKEN": "pk.eyJ1IjoiY2FybG9zaGVucmlxdWVmcmFuY2EiLCJhIjoiY21udDc1M2g4MGx6aDJycTFzeTN0d2N4cSJ9.52ujdv0Fq3ZXxQOiTCp6ZQ"
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
