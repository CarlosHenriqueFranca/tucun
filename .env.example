# ============================================================
# TUCUN — Variáveis de Ambiente
# ============================================================
# COPIE este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no Git!
# ============================================================

# ── APP ─────────────────────────────────────────────────────
NODE_ENV=development
APP_NAME=Tucun
APP_URL=http://localhost:3000
API_URL=http://localhost:3333
API_PREFIX=api

# ── DATABASE ────────────────────────────────────────────────
DATABASE_URL=postgresql://tucun:tucun_dev_password@localhost:5432/tucun
POSTGRES_PASSWORD=tucun_dev_password
POSTGRES_DB=tucun
POSTGRES_USER=tucun

# ── REDIS ───────────────────────────────────────────────────
REDIS_URL=redis://:tucun_redis_dev@localhost:6379
REDIS_PASSWORD=tucun_redis_dev

# ── JWT ─────────────────────────────────────────────────────
# Gerar com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=GERE_UMA_CHAVE_SEGURA_AQUI_64_CARACTERES
JWT_REFRESH_SECRET=GERE_OUTRA_CHAVE_SEGURA_AQUI_64_CARACTERES
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── MAPBOX ──────────────────────────────────────────────────
# Criar em: https://mapbox.com → Account → Access Tokens
MAPBOX_PUBLIC_TOKEN=pk.eyJ...SEU_TOKEN_AQUI
MAPBOX_SECRET_TOKEN=sk.eyJ...SEU_TOKEN_SECRETO

# ── ZAPI (WhatsApp) ─────────────────────────────────────────
# Criar em: https://z-api.io
ZAPI_INSTANCE=SUA_INSTANCIA
ZAPI_TOKEN=SEU_TOKEN
ZAPI_CLIENT_TOKEN=SEU_CLIENT_TOKEN

# ── ASAAS (Pagamentos) ──────────────────────────────────────
# Criar em: https://asaas.com/developers
# Sandbox (testes): https://sandbox.asaas.com
ASAAS_API_KEY=$aas_SUA_CHAVE_AQUI
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Produção: https://api.asaas.com/v3
ASAAS_WEBHOOK_TOKEN=TOKEN_PARA_VALIDAR_WEBHOOKS

# ── AWS S3 (Armazenamento de mídias) ────────────────────────
# Criar em: https://aws.amazon.com → IAM → Users
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=SUA_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=SUA_SECRET_KEY
AWS_S3_BUCKET=tucun-media
AWS_CLOUDFRONT_URL=https://XXXXX.cloudfront.net

# ── FIREBASE (Push Notifications) ───────────────────────────
# Criar em: https://console.firebase.google.com
FIREBASE_PROJECT_ID=tucun-app
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tucun-app.iam.gserviceaccount.com

# ── OAUTH ───────────────────────────────────────────────────
# Google: https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=XXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXX

# Facebook: https://developers.facebook.com
FACEBOOK_APP_ID=XXXX
FACEBOOK_APP_SECRET=XXXX

# ── OPENTELEMETRY (Observabilidade) ─────────────────────────
# Grafana Cloud grátis: https://grafana.com/products/cloud/
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-sa-east-1.grafana.net/otlp
GRAFANA_CLOUD_TOKEN=glc_XXXX

# ── PGADMIN (Dev apenas) ────────────────────────────────────
PGADMIN_EMAIL=admin@tucun.app
PGADMIN_PASSWORD=admin123

# ── RATE LIMITING ───────────────────────────────────────────
RATE_LIMIT_TTL=60000
RATE_LIMIT_REQUESTS=100

# ── UPLOAD ──────────────────────────────────────────────────
MAX_FILE_SIZE_MB=100
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/webm
